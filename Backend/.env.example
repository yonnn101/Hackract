DATABASE_URL="postgresql://postgres:root@localhost:5432/HackractDB"

# Auth0 Configuration
AUTH0_AUDIENCE="https://example.us.auth0.com/api/v2/"
AUTH0_ISSUER_BASE_URL="https://example.us.auth0.com/"
JWT_ACCESS_SECRET=#Jwt example
PORT=4000
NODE_ENV=development
FRONTEND_BASE_URL="http://localhost:5173"
AI_AGENT_URL="http://127.0.0.1:8008"
AI_AGENT_WS_URL="ws://127.0.0.1:8008"

# =========================
# Email Providers (Verification + Reset)
# =========================

# SMTP (Nodemailer) - REQUIRED for "real" email verification via SMTP
# If these are set, the backend will send verification + reset emails via SMTP.
SMTP_HOST=smtp-relay.brevo.com
SMTP_PORT=587
SMTP_SECURE=true
SMTP_USER=example@smtp-brevo.com
SMTP_PASS=xsmtpsib-12345679
SMTP_FROM=Hackract Corp <[EMAIL_ADDRESS]>

# =========================
# MinIO Storage (Local S3-compatible)
# =========================
MINIO_ENDPOINT=http://localhost:9000
MINIO_PORT=9000
MINIO_ACCESS_KEY=hackract_admin
MINIO_SECRET_KEY=hackract_secret_123
MINIO_BUCKET_NAME=hackract-files
