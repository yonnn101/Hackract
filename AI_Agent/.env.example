# =========================================
# LLM Provider Configuration
# =========================================
# Supported providers: openrouter, openai, anthropic, gemini, github, ollama, custom, ...
LLM_PROVIDER=openrouter

# API Key (not needed for local Ollama). For GitHub Models use a GitHub PAT with models access.
API_KEY=your_api_key_here
# Optional alias for GitHub Models only (used if API_KEY is empty):
# GITHUB_TOKEN=ghp_...
#
# GitHub Models (~8k input tokens / request). Tune if you still see "Request body too large":
# GITHUB_MAX_CONTEXT_TOKENS=4500
# GITHUB_MAX_COMPLETION_TOKENS=1536
# GITHUB_MAX_INPUT_BUDGET=5200
# GITHUB_MAX_SYSTEM_CHARS=12000

# =========================================
# Model Selection
# =========================================
# Chat Model: Main reasoning model (higher capability)
# For OpenRouter: anthropic/claude-3.5-sonnet, openai/gpt-4, etc.
# For OpenAI: gpt-4, gpt-4-turbo-preview, gpt-3.5-turbo
# For Anthropic: claude-3-opus-20240229, claude-3-sonnet-20240229
# For Ollama: llama3.1:70b, mistral:7b, codellama:13b, etc.
CHAT_MODEL=anthropic/claude-3.5-sonnet

# Utility Model: Quick tasks (parsing, formatting) - can be smaller/cheaper
UTILITY_MODEL=anthropic/claude-3-haiku

# Embedding Model: For vector search/memory
# OpenAI: text-embedding-3-small, text-embedding-3-large
# For Ollama: nomic-embed-text, mxbai-embed-large
EMBEDDING_MODEL=text-embedding-3-small

# Memory Configuration
MEMORY_DIR=./memory
MEMORY_ENABLED=true

# Code Execution
CODE_EXEC_SSH_ENABLED=false
CODE_EXEC_SSH_ADDR=localhost
CODE_EXEC_SSH_PORT=22
CODE_EXEC_SSH_USER=root
CODE_EXEC_SSH_PASS=

# =========================================
# Provider-Specific Settings
# =========================================
# For Ollama: Specify the base URL (default: http://localhost:11434)
OLLAMA_BASE_URL=http://localhost:11434

# For Custom API: Specify custom endpoint
CUSTOM_API_BASE=

# =========================================
# Agent Configuration
# =========================================
AGENT_NAME=HackrAct
MAX_ITERATIONS=25
TEMPERATURE=0.7

# Logging
LOG_LEVEL=INFO
LOG_DIR=./logs

# =========================================
# API Server (optional)
# =========================================
# Port for API server (default: 8008). Health: GET /api/health
# AI_AGENT_PORT=8008
# Comma-separated origins for CORS (leave unset for "*" in dev)
# AI_AGENT_CORS_ORIGINS=https://myapp.com,https://app.myapp.com
# Max message length (chars) and WebSocket payload (bytes). Defaults: 65536
# AI_AGENT_MAX_MESSAGE_LENGTH=65536
# AI_AGENT_MAX_WS_PAYLOAD_BYTES=65536

# =========================================
# Memory (optional)
# =========================================
# Embedding dimension when embedding API fails (1536 for OpenAI text-embedding-3-*)
# EMBEDDING_FALLBACK_DIMENSION=1536
